# Copy to backend/.env and/or repo-root .env (never commit real secrets).
# core/config.py reads these keys — defaults live here only, not in Python.

# PostgreSQL (psycopg)
DATABASE_URL=
# Alembic migrations (optional; Neon 등 pooler 우회용 direct endpoint)
DIRECT_URL=

# Redis (optional session cache)
REDIS_URL=

# Outbound API keys (Anthropic Claude + Cohere embeddings)
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO

# Dev without PostgreSQL: set true (trials lost on backend restart)
# Docker Compose overrides this to false and uses Postgres.
USE_MEMORY_STORE=true

# Frontend CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
