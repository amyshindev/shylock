# PostgreSQL (psycopg)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/shylock

# Redis (optional session cache)
REDIS_URL=redis://localhost:6379/0

# Outbound API keys — never expose to frontend
LLM_API_KEY=
COHERE_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO

# Dev: skip PostgreSQL (set false when DB is ready)
USE_MEMORY_STORE=true

# Frontend CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
