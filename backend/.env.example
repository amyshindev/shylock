# Copy to backend/.env and/or repo-root .env (never commit real secrets).
# core/config.py reads these keys — defaults live here only, not in Python.

# PostgreSQL (psycopg)
DATABASE_URL=
# Alembic migrations (optional; Neon 등 pooler 우회용 direct endpoint)
DIRECT_URL=

# Redis (optional session cache)
REDIS_URL=

# Outbound API keys (Anthropic Claude + Cohere embeddings)
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# HMAC secret for /docs login session cookie (optional; has a weak default for local)
DOCS_SESSION_SECRET=change-me-docs-session-secret

# Admin credentials for Swagger /docs login
DOCS_ADMIN_USERNAME=admin
DOCS_ADMIN_PASSWORD=change-me-docs-admin-password

# HMAC secret for game user login session cookies
AUTH_SESSION_SECRET=change-me-auth-session-secret

# Google OAuth login (console.cloud.google.com; empty values disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/shylock-trial/auth/google/callback
# Frontend origin to return to after social login
FRONTEND_BASE_URL=http://localhost:3000

# App
APP_ENV=development
LOG_LEVEL=INFO

# Dev without PostgreSQL: set true (trials lost on backend restart)
# Docker Compose overrides this to false and uses Postgres.
USE_MEMORY_STORE=true

# Frontend CORS (comma-separated; include production frontend domains)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://shylock-trial.xyz,https://www.shylock-trial.xyz
