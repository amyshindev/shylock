# API / game backend container (api.shylock-trial.xyz → backend:8000)
# Must NOT contain JWT_PRIVATE_KEY

APP_ENV=production
LOG_LEVEL=INFO
USE_MEMORY_STORE=false

DATABASE_URL=
DIRECT_URL=
REDIS_URL=redis://redis:6379/0

ANTHROPIC_API_KEY=
COHERE_API_KEY=

CORS_ORIGINS=https://shylock-trial.xyz,https://www.shylock-trial.xyz
FRONTEND_BASE_URL=https://shylock-trial.xyz

# Public key only — verify access tokens issued by auth
JWT_PUBLIC_KEY=
SERVICE_AUD=shylock-api

# Existing docs admin / game login (legacy HMAC cookie) — optional
DOCS_SESSION_SECRET=
DOCS_ADMIN_USERNAME=
DOCS_ADMIN_PASSWORD=
AUTH_SESSION_SECRET=

# Legacy Google login on API (if still used) — prefer auth gateway redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://auth.shylock-trial.xyz/auth/callback/google
