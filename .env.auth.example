# Auth gateway container only (auth.shylock-trial.xyz → auth:9000)
# Generate keys: bash scripts/generate_jwt_keys.sh

APP_ENV=production
REDIS_URL=redis://redis:6379/0
SERVICE_AUD=shylock-api
COOKIE_DOMAIN=.shylock-trial.xyz
FRONTEND_BASE_URL=https://shylock-trial.xyz

# Base64-encoded PEMs (preferred) or raw PEM with \n
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://auth.shylock-trial.xyz/auth/callback/google

ACCESS_TOKEN_TTL_MIN=10
REFRESH_TOKEN_TTL_SEC=1209600
